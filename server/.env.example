# PC-side config for the weather/air-quality importer. Copy to `.env` (gitignored)
# and fill in the keyed sources you've collected. The four keyless sources
# (Open-Meteo weather + air quality, RIVM Luchtmeetnet, sensor.community) work with
# none of this set.

# Your coordinates. By default these are read from the firmware's
# ../firmware/src/secrets.h (STATION_LAT / STATION_LON) so the station has one
# source of truth. Uncomment below to override, or point AIRMON_FIRMWARE_SECRETS
# at a different secrets.h. Falls back to the Soestdijk placeholder if neither is set.
# AIRMON_LAT=52.179722
# AIRMON_LON=5.284722

# How far out to search for community stations, and how often to poll.
WEATHER_RADIUS_KM=10
WEATHER_POLL_SEC=600
# WEATHER_ENABLED=0          # set to disable the importer entirely

# --- keyed sources: each self-enables only when its vars are present ---

# KNMI Data Platform Open Data API key -> https://developer.dataplatform.knmi.nl
# KNMI_API_KEY=

# Netatmo OAuth app -> https://dev.netatmo.com (scope read_station)
# NETATMO_CLIENT_ID=
# NETATMO_CLIENT_SECRET=
# NETATMO_REFRESH_TOKEN=

# Weather Underground PWS API key + the station id to query
# WU_API_KEY=
# WU_STATION_ID=

# --- aircraft (ADS-B via readsb) -------------------------------------------
# Station location reuses AIRMON_LAT/AIRMON_LON above. readsb decodes the V4 and
# writes aircraft.json; the server polls it, locates planes vs home, and logs them.
# AIRCRAFT_ENABLED=0                              # disable the aircraft poller
# AIRCRAFT_JSON_PATH=/run/readsb/aircraft.json    # readsb output file (default)
# AIRCRAFT_JSON_URL=                              # or read over HTTP instead of a file
# AIRCRAFT_POLL_SEC=1                             # snapshot read cadence
# AIRCRAFT_STALE_SEC=60                           # drop aircraft not heard from within this
# AIRCRAFT_MAX_RANGE_KM=300                       # ignore beyond this (radio horizon)
# AIRCRAFT_LOG_SEC=15                             # log each aircraft to the DB at most this often
# Public ADS-B reference feed: cross-correlates against the local SDR and fills the
# map when local reception is weak. Only the local SDR's sightings are logged to the DB.
# AIRCRAFT_PUBLIC_ENABLED=1                        # set 0 to disable the outbound call
# AIRCRAFT_PUBLIC_URL=https://api.airplanes.live/v2/point/{lat}/{lon}/{radius_nm}  # or adsb.lol etc.
# AIRCRAFT_PUBLIC_POLL_SEC=10                      # how often to refresh the reference feed
# AIRCRAFT_PUBLIC_RADIUS_KM=30                     # query radius (kept just beyond the map's max display)
